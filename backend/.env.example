# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# NVD API Key (free) — without this, NVD is rate limited to 5 requests/30s
# Get yours at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# Allowed frontend origins (comma-separated, no trailing slash)
# Development + production example:
ALLOWED_ORIGINS=http://localhost:3000,https://dependency-analyzer-sky2194s-projects.vercel.app

# Keep true if you use Vercel preview deployments.
ALLOW_VERCEL_PREVIEWS=true
